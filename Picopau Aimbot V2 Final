    Title.TextSize = 16
    Title.TextXAlignment = Enum.TextXAlignment.Left
    
    local Container = Instance.new("Frame")
    Container.Name = "Container"
    Container.Parent = Main
    Container.BackgroundTransparency = 1
    Container.Position = UDim2.new(0, 10, 0, 50)
    Container.Size = UDim2.new(1, -20, 1, -90)
    
    local TabButtons = Instance.new("Frame")
    TabButtons.Parent = Container
    TabButtons.BackgroundTransparency = 1
    TabButtons.Size = UDim2.new(0, 80, 1, 0)
    
    local PageContainer = Instance.new("Frame")
    PageContainer.Parent = Container
    PageContainer.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    PageContainer.Position = UDim2.new(0, 90, 0, 0)
    PageContainer.Size = UDim2.new(1, -90, 1, 0)
    Instance.new("UICorner", PageContainer)
    
    local Credits = Instance.new("TextLabel")
    Credits.Parent = Main
    Credits.BackgroundTransparency = 1
    Credits.Position = UDim2.new(0, 0, 1, -35)
    Credits.Size = UDim2.new(1, 0, 0, 30)
    Credits.Font = Enum.Font.Gotham
    Credits.Text = "Desenvolvido por: picopau & Manus ai"
    Credits.TextColor3 = Color3.fromRGB(100, 100, 100)
    Credits.TextSize = 12
    
    local Pages = {}
    local CurrentPage = nil
    
    local function CreatePage(name)
        local Page = Instance.new("ScrollingFrame")
        Page.Parent = PageContainer
        Page.BackgroundTransparency = 1
        Page.Size = UDim2.new(1, -10, 1, -10)
        Page.Position = UDim2.new(0, 5, 0, 5)
        Page.CanvasSize = UDim2.new(0, 0, 0, 0)
        Page.ScrollBarThickness = 2
        Page.Visible = false
        Page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        
        local Layout = Instance.new("UIListLayout", Page)
        Layout.Padding = UDim.new(0, 5)
        Layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        
        local Btn = Instance.new("TextButton")
        Btn.Parent = TabButtons
        Btn.Size = UDim2.new(1, 0, 0, 30)
        Btn.Position = UDim2.new(0, 0, 0, #Pages * 35)
        Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        Btn.Font = Enum.Font.GothamBold
        Btn.Text = name
        Btn.TextColor3 = Color3.new(0.6, 0.6, 0.6)
        Btn.TextSize = 12
        Instance.new("UICorner", Btn)
        
        Btn.MouseButton1Click:Connect(function()
            if CurrentPage then CurrentPage.Visible = false end
            for _, b in pairs(TabButtons:GetChildren()) do
                if b:IsA("TextButton") then b.TextColor3 = Color3.new(0.6, 0.6, 0.6) end
            end
            Page.Visible = true
            Btn.TextColor3 = Color3.new(1, 1, 1)
            CurrentPage = Page
        end)
        
        Pages[name] = Page
        if not CurrentPage then
            Page.Visible = true
            Btn.TextColor3 = Color3.new(1, 1, 1)
            CurrentPage = Page
        end
        return Page
    end
    
    local function AddToggle(page, text, config, key)
        local Tgl = Instance.new("TextButton")
        Tgl.Parent = page
        Tgl.Size = UDim2.new(0.9, 0, 0, 35)
        Tgl.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Tgl.Font = Enum.Font.Gotham
        Tgl.Text = text .. ": " .. (config[key] and "ON" or "OFF")
        Tgl.TextColor3 = config[key] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        Tgl.TextSize = 12
        Instance.new("UICorner", Tgl)
        
        Tgl.MouseButton1Click:Connect(function()
            config[key] = not config[key]
            Tgl.Text = text .. ": " .. (config[key] and "ON" or "OFF")
            Tgl.TextColor3 = config[key] and Color3.new(0, 1, 0) or Color3.new(1, 0, 0)
        end)
    end
    
    local function AddButton(page, text, callback)
        local Btn = Instance.new("TextButton")
        Btn.Parent = page
        Btn.Size = UDim2.new(0.9, 0, 0, 35)
        Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Btn.Font = Enum.Font.Gotham
        Btn.Text = text
        Btn.TextColor3 = Color3.new(1, 1, 1)
        Btn.TextSize = 12
        Instance.new("UICorner", Btn)
        Btn.MouseButton1Click:Connect(callback)
    end

    local function AddDropdown(page, text, options, config, key)
        local Drop = Instance.new("TextButton")
        Drop.Parent = page
        Drop.Size = UDim2.new(0.9, 0, 0, 35)
        Drop.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        Drop.Font = Enum.Font.Gotham
        local current = config[key]
        Drop.Text = text .. ": " .. (typeof(current) == "Color3" and "Cor Selecionada" or tostring(current))
        Drop.TextColor3 = Color3.new(1, 1, 1)
        Drop.TextSize = 12
        Instance.new("UICorner", Drop)
        
        local idx = 1
        Drop.MouseButton1Click:Connect(function()
            idx = idx + 1
            if idx > #options then idx = 1 end
            config[key] = options[idx]
            local val = options[idx]
            Drop.Text = text .. ": " .. (typeof(val) == "Color3" and "Cor Selecionada" or tostring(val))
            if typeof(val) == "Color3" then Drop.TextColor3 = val end
        end)
    end
    
    -- Criar Páginas
    local AimPage = CreatePage("Aimbot")
    local EspPage = CreatePage("ESP")
    local MiscPage = CreatePage("Misc")
    
    -- Aimbot
    AddToggle(AimPage, "Ativar Aimbot", _G.Config.Aimbot, "Enabled")
    AddToggle(AimPage, "Checar Time", _G.Config.Aimbot, "TeamCheck")
    AddToggle(AimPage, "Lock Instantâneo", _G.Config.Aimbot, "Instant")
    AddDropdown(AimPage, "Alvo", {"Head", "HumanoidRootPart"}, _G.Config.Aimbot, "TargetPart")
    
    -- ESP
    AddToggle(EspPage, "Ativar ESP", _G.Config.ESP, "Enabled")
    AddToggle(EspPage, "Mostrar Box", _G.Config.ESP, "Box")
    AddToggle(EspPage, "Mostrar Nomes", _G.Config.ESP, "Names")
    AddDropdown(EspPage, "Cor", {Color3.new(1,0,0), Color3.new(0,1,0), Color3.new(0,0,1), Color3.new(1,1,1)}, _G.Config.ESP, "Color")
    
    -- Misc
    AddButton(MiscPage, "Resetar Movimentação", function()
        pcall(function()
            LocalPlayer.Character.Humanoid.WalkSpeed = 16
            LocalPlayer.Character.Humanoid.JumpPower = 50
        end)
    end)
    AddButton(MiscPage, "Fechar Script", function()
        _G.PicopauV2_Active = false
        CleanupOldUI()
    end)
end

-- Inicialização
for _, p in pairs(Players:GetPlayers()) do ApplyESP(p) end
