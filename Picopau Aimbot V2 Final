-- Limpeza de UI Antiga
local function CleanupOldUI()
    local targets = {"ManusV2", "ManusMenu", "ManusLoading", "PicopauUI"}
    local coreGui = game:GetService("CoreGui")
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    
    for _, name in ipairs(targets) do
        pcall(function()
            if coreGui:FindFirstChild(name) then coreGui[name]:Destroy() end
            if playerGui and playerGui:FindFirstChild(name) then playerGui[name]:Destroy() end
        end)
    end
end

-- Lógica de ESP (Corrigida para não travar o script)
local function ApplyESP(Player)
    if Player == LocalPlayer then return end
    
    local function CreateESP()
        local Character = Player.Character or Player.CharacterAdded:Wait()
        local Root = Character:WaitForChild("HumanoidRootPart", 10)
        local Hum = Character:WaitForChild("Humanoid", 10)
        
        if not Root or not Hum then return end
        
        local Folder = Instance.new("Folder")
        Folder.Name = "PicopauESP_" .. Player.Name
        Folder.Parent = Camera
        
        local Box = Instance.new("BoxHandleAdornment", Folder)
        Box.Size = Vector3.new(4, 6, 2)
        Box.AlwaysOnTop = true
        Box.ZIndex = 5
        Box.Transparency = _G.Config.ESP.Transparency
        
        local NameTag = Instance.new("BillboardGui", Folder)
        NameTag.Size = UDim2.new(0, 100, 0, 20)
        NameTag.AlwaysOnTop = true
        NameTag.StudsOffset = Vector3.new(0, 3, 0)
        
        local NameLabel = Instance.new("TextLabel", NameTag)
        NameLabel.Size = UDim2.new(1, 0, 1, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.TextColor3 = Color3.new(1, 1, 1)
        NameLabel.TextStrokeTransparency = 0
        NameLabel.Font = Enum.Font.GothamBold
        NameLabel.TextSize = 12
        NameLabel.Text = Player.Name
        
        local Connection
        Connection = RunService.RenderStepped:Connect(function()
            if not _G.PicopauV2_Active or not Character or not Character.Parent or not Player.Parent then
                Folder:Destroy()
                Connection:Disconnect()
                return
            end
            
            local IsVisible = _G.Config.ESP.Enabled
            if _G.Config.ESP.TeamCheck and Player.Team == LocalPlayer.Team then IsVisible = false end
            
            Box.Visible = IsVisible and _G.Config.ESP.Box
            Box.Adornee = Character
            Box.Color3 = _G.Config.ESP.Color
            
            NameTag.Enabled = IsVisible and _G.Config.ESP.Names
            NameTag.Adornee = Root
        end)
    end
    
    task.spawn(CreateESP)
    Player.CharacterAdded:Connect(function() task.spawn(CreateESP) end)
end

-- Lógica de Aimbot
RunService.RenderStepped:Connect(function()
    if not _G.PicopauV2_Active or not _G.Config.Aimbot.Enabled then return end
    
    local Target = nil
    local Closest = math.huge
    
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(_G.Config.Aimbot.TargetPart) then
            local Hum = p.Character:FindFirstChild("Humanoid")
            if Hum and Hum.Health > 0 then
                if not _G.Config.Aimbot.TeamCheck or p.Team ~= LocalPlayer.Team then
                    local ScreenPos, OnScreen = Camera:WorldToScreenPoint(p.Character[_G.Config.Aimbot.TargetPart].Position)
                    if OnScreen then
                        local MousePos = UserInputService:GetMouseLocation()
                        local Dist = (Vector2.new(ScreenPos.X, ScreenPos.Y) - MousePos).Magnitude
                        if Dist < Closest then
                            Closest = Dist
                            Target = p.Character[_G.Config.Aimbot.TargetPart]
                        end
                    end
                end
            end
        end
    end
    
    if Target then
        if _G.Config.Aimbot.Instant then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Position)
        else
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Target.Position), _G.Config.Aimbot.Smoothness)
        end
    end
end)

-- Lógica de Movimentação (Fix)
task.spawn(function()
    while _G.PicopauV2_Active do
        pcall(function()
            if _G.Config.Player.FixMovement and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
                local Hum = LocalPlayer.Character.Humanoid
                if Hum.WalkSpeed < 16 then Hum.WalkSpeed = 16 end
            end
        end)
        task.wait(1)
    end
end)

