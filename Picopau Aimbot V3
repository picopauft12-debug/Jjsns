    Title.TextColor3 = Color3.fromRGB(0, 170, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 24
    Title.BackgroundTransparency = 1

    local Status = Instance.new("TextLabel", Main)
    Status.Size = UDim2.new(1, 0, 0, 30)
    Status.Position = UDim2.new(0, 0, 0.5, 0)
    Status.Text = "Carregando componentes..."
    Status.TextColor3 = Color3.new(1, 1, 1)
    Status.Font = Enum.Font.Gotham
    Status.TextSize = 14
    Status.BackgroundTransparency = 1

    local BarBG = Instance.new("Frame", Main)
    BarBG.Size = UDim2.new(0.8, 0, 0, 4)
    BarBG.Position = UDim2.new(0.1, 0, 0.8, 0)
    BarBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Instance.new("UICorner", BarBG)

    local BarFill = Instance.new("Frame", BarBG)
    BarFill.Size = UDim2.new(0, 0, 1, 0)
    BarFill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    Instance.new("UICorner", BarFill)

    task.spawn(function()
        task.wait(0.5)
        Status.Text = "Executando Script Remoto..."
        TweenService:Create(BarFill, TweenInfo.new(1), {Size = UDim2.new(0.7, 0, 1, 0)}):Play()
        pcall(function() loadstring(game:HttpGet(REMOTE_SCRIPT_URL))() end)
        
        task.wait(0.5)
        Status.Text = "Iniciando Picopau V3..."
        TweenService:Create(BarFill, TweenInfo.new(0.5), {Size = UDim2.new(1, 0, 1, 0)}):Play()
        task.wait(0.5)
        ScreenGui:Destroy()
        CreateMainUI()
    end)
end

-- LÓGICA ESP V3
local function CreateESP(Player)
    if Player == LocalPlayer then return end
    local function Setup()
        local Character = Player.Character or Player.CharacterAdded:Wait()
        local Root = Character:WaitForChild("HumanoidRootPart", 10)
        if not Root then return end

        local Folder = Instance.new("Folder", Camera)
        Folder.Name = "ESP_V3_" .. Player.Name

        local Box = Instance.new("BoxHandleAdornment", Folder)
        Box.Size = Vector3.new(4, 5, 2)
        Box.AlwaysOnTop = true
        Box.ZIndex = 5
        Box.Transparency = 0.5

        local NameTag = Instance.new("BillboardGui", Folder)
        NameTag.Size = UDim2.new(0, 100, 0, 20)
        NameTag.AlwaysOnTop = true
        NameTag.StudsOffset = Vector3.new(0, 3, 0)
        local NameLabel = Instance.new("TextLabel", NameTag)
        NameLabel.Size = UDim2.new(1, 0, 1, 0)
        NameLabel.BackgroundTransparency = 1
        NameLabel.Font = Enum.Font.GothamBold
        NameLabel.TextSize = 12
        NameLabel.Text = Player.Name

        RunService.RenderStepped:Connect(function()
            if not Character or not Character.Parent or not Player.Parent then Folder:Destroy() return end
            local Visible = _G.Config.ESP.Enabled
            if _G.Config.ESP.TeamCheck and Player.Team == LocalPlayer.Team then Visible = false end
            
            Box.Visible = Visible and _G.Config.ESP.Box
            Box.Adornee = Character
            Box.Color3 = _G.Config.ESP.BoxColor
            
            NameTag.Enabled = Visible and _G.Config.ESP.Names
            NameTag.Adornee = Root
            NameLabel.TextColor3 = _G.Config.ESP.NameColor
        end)
    end
    Setup()
    Player.CharacterAdded:Connect(Setup)
end

-- LÓGICA AIMBOT V3 (FOCO NO MAIS PRÓXIMO DO TIME INIMIGO)
RunService.RenderStepped:Connect(function()
    if _G.Config.Aimbot.Enabled then
        local Target = nil
        local Dist = math.huge
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                -- Sempre checa se é inimigo se TeamCheck estiver ON
                if not _G.Config.Aimbot.TeamCheck or p.Team ~= LocalPlayer.Team then
                    local Part = p.Character:FindFirstChild(_G.Config.Aimbot.TargetPart)
                    if Part then
                        local Pos, OnScreen = Camera:WorldToScreenPoint(Part.Position)
                        if OnScreen then
                            local Mag = (Vector2.new(Pos.X, Pos.Y) - UserInputService:GetMouseLocation()).Magnitude
                            if Mag < Dist then Dist = Mag Target = p end
                        end
                    end
                end
            end
        end
        if Target then
            local TargetPos = Target.Character[_G.Config.Aimbot.TargetPart].Position
            if _G.Config.Aimbot.Instant then
                Camera.CFrame = CFrame.new(Camera.CFrame.Position, TargetPos)
            else
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, TargetPos), _G.Config.Aimbot.Smoothness)
            end
        end
    end
end)

-- INTERFACE V3
function CreateMainUI()
    local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
    ScreenGui.Name = "PicopauV3"

    local Main = Instance.new("Frame", ScreenGui)
    Main.Size = UDim2.new(0, 480, 0, 350)
    Main.Position = UDim2.new(0.5, -240, 0.5, -175)
    Main.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Main.Active = true
    Main.Draggable = true
    Instance.new("UICorner", Main)

    -- Sidebar
    local Sidebar = Instance.new("Frame", Main)
    Sidebar.Size = UDim2.new(0, 120, 1, 0)
    Sidebar.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", Sidebar)

    local Title = Instance.new("TextLabel", Sidebar)
    Title.Size = UDim2.new(1, 0, 0, 50)
    Title.Text = "PICOPAU V3"
    Title.TextColor3 = Color3.fromRGB(0, 170, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.BackgroundTransparency = 1

    local Content = Instance.new("Frame", Main)
    Content.Size = UDim2.new(1, -130, 1, -20)
    Content.Position = UDim2.new(0, 125, 0, 10)
    Content.BackgroundTransparency = 1

    local Pages = {}
    local function CreatePage(name)
        local Page = Instance.new("ScrollingFrame", Content)
        Page.Size = UDim2.new(1, 0, 1, 0)
        Page.BackgroundTransparency = 1
        Page.Visible = false
        Page.ScrollBarThickness = 0
        local Layout = Instance.new("UIListLayout", Page)
        Layout.Padding = UDim.new(0, 10)
        Pages[name] = Page
        return Page
    end

    local function CreateTabBtn(name, pos)
        local Btn = Instance.new("TextButton", Sidebar)
        Btn.Size = UDim2.new(0.9, 0, 0, 35)
        Btn.Position = UDim2.new(0.05, 0, 0, pos)
        Btn.Text = name
        Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
        Btn.TextColor3 = Color3.new(1, 1, 1)
        Btn.Font = Enum.Font.GothamBold
        Instance.new("UICorner", Btn)
        Btn.MouseButton1Click:Connect(function()
            for _, p in pairs(Pages) do p.Visible = false end
            Pages[name].Visible = true
        end)
    end

    -- Páginas
    local AimPage = CreatePage("Aimbot")
    local EspPage = CreatePage("ESP")
    local CreditsPage = CreatePage("Créditos")

    CreateTabBtn("Aimbot", 60)
    CreateTabBtn("ESP", 105)
    CreateTabBtn("Créditos", 150)

    -- Componentes UI
    local function AddToggle(parent, text, config, key)
        local F = Instance.new("Frame", parent)
        F.Size = UDim2.new(1, 0, 0, 40)
        F.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Instance.new("UICorner", F)
        local L = Instance.new("TextLabel", F)
        L.Size = UDim2.new(0.7, 0, 1, 0)
        L.Position = UDim2.new(0, 10, 0, 0)
        L.Text = text
        L.TextColor3 = Color3.new(1, 1, 1)
        L.BackgroundTransparency = 1
        L.TextXAlignment = "Left"
        local B = Instance.new("TextButton", F)
        B.Size = UDim2.new(0, 40, 0, 20)
        B.Position = UDim2.new(1, -50, 0.5, -10)
        B.Text = ""
        B.BackgroundColor3 = config[key] and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(60, 60, 60)
        Instance.new("UICorner", B).CornerRadius = UDim.new(1, 0)
        B.MouseButton1Click:Connect(function()
            config[key] = not config[key]
            B.BackgroundColor3 = config[key] and Color3.fromRGB(0, 170, 255) or Color3.fromRGB(60, 60, 60)
        end)
    end

    local function AddSelector(parent, text, options, config, key)
        local F = Instance.new("Frame", parent)
        F.Size = UDim2.new(1, 0, 0, 40)
        F.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        Instance.new("UICorner", F)
        local L = Instance.new("TextLabel", F)
        L.Text = text .. ": " .. config[key]
        L.Size = UDim2.new(1, 0, 1, 0)
        L.TextColor3 = Color3.new(1, 1, 1)
        L.BackgroundTransparency = 1
        local B = Instance.new("TextButton", F)
        B.Size = UDim2.new(1, 0, 1, 0)
        B.BackgroundTransparency = 1
        B.Text = ""
        local i = 1
        B.MouseButton1Click:Connect(function()
            i = i + 1 if i > #options then i = 1 end
            config[key] = options[i]
            L.Text = text .. ": " .. options[i]
        end)
    end

    -- Configuração Aimbot
    AddToggle(AimPage, "Ativar Aimbot", _G.Config.Aimbot, "Enabled")
    AddToggle(AimPage, "Team Check (Inimigos)", _G.Config.Aimbot, "TeamCheck")
    AddToggle(AimPage, "Mira Instantânea", _G.Config.Aimbot, "Instant")
    AddSelector(AimPage, "Parte do Alvo", {"Head", "UpperTorso", "LeftFoot"}, _G.Config.Aimbot, "TargetPart")

    -- Configuração ESP
    AddToggle(EspPage, "Ativar ESP", _G.Config.ESP, "Enabled")
    AddToggle(EspPage, "Mostrar Box", _G.Config.ESP, "Box")
    AddToggle(EspPage, "Mostrar Nomes", _G.Config.ESP, "Names")
    AddSelector(EspPage, "Cor da Box", {"Red", "Blue", "Green", "Yellow"}, _G.Config.ESP, "BoxColor")
    
    -- Lógica de cores simplificada para o seletor
    local colorMap = {Red = Color3.new(1,0,0), Blue = Color3.new(0,0,1), Green = Color3.new(0,1,0), Yellow = Color3.new(1,1,0)}
    _G.Config.ESP.BoxColor = colorMap["Red"]
    
    -- Aba Créditos
    local C1 = Instance.new("TextLabel", CreditsPage)
    C1.Size = UDim2.new(1, 0, 0, 40)
    C1.Text = "Dono: Picopau"
    C1.TextColor3 = Color3.fromRGB(0, 170, 255)
    C1.Font = Enum.Font.GothamBold
    C1.BackgroundTransparency = 1
    
    local C2 = Instance.new("TextLabel", CreditsPage)
    C2.Size = UDim2.new(1, 0, 0, 40)
    C2.Text = "Desenvolvido por: Manus Ai"
    C2.TextColor3 = Color3.new(1, 1, 1)
    C2.Font = Enum.Font.Gotham
    C2.BackgroundTransparency = 1

    Pages["Aimbot"].Visible = true
end

for _, p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)
ShowLoadingScreen()
